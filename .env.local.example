# Cognee Cloud (platform.cognee.ai -> API Keys page)
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=
COGNEE_TENANT_ID=
# Upstash Redis (added in P1)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Groq (console.groq.com -> API Keys). Optional: absent = actions layer off
GROQ_API_KEY=

# Auth.js / Google sign-in (dashboard access + team membership)
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 33`)
AUTH_SECRET=
# Google OAuth client (console.cloud.google.com -> APIs & Services -> Credentials).
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
# For local dev also add: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
